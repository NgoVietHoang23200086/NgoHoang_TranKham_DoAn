@page
@using JobBoard.Domain.Enums
@model JobBoard.Web.Pages.Jobs.ApplicationsModel
@{
    ViewData["Title"] = "Quản lý đơn ứng tuyển";
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Dashboard/Index" class="text-decoration-none">Bảng điều khiển</a></li>
            <li class="breadcrumb-item active" aria-current="page">Đơn ứng tuyển</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="card bg-light border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <span class="badge bg-primary px-3 py-2 mb-2">QUẢN LÝ ĐƠN ỨNG TUYỂN</span>
                    <h2 class="mb-1 text-dark fw-bold">@Model.Job?.Title</h2>
                    <p class="text-muted mb-0">
                        <i class="bi bi-geo-alt text-danger me-1"></i> @Model.Job?.Location | 
                        <i class="bi bi-cash text-success me-1"></i> @Model.Job?.Salary.ToString("N0") VNĐ | 
                        <i class="bi bi-calendar-event me-1"></i> Hạn nộp: @Model.Job?.ExpiryDate.ToString("dd/MM/yyyy")
                    </p>
                </div>
                <div class="bg-white px-4 py-3 rounded shadow-sm text-center">
                    <span class="d-block fs-3 fw-bold text-primary">@Model.Applications.Count()</span>
                    <span class="text-muted small">Tổng đơn ứng tuyển</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (Model.SuccessMessage != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (Model.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Applications List -->
    <h4 class="mb-3 fw-bold"><i class="bi bi-person-lines-fill me-2"></i>Danh sách ứng viên</h4>

    @if (!Model.Applications.Any())
    {
        <div class="card shadow-sm border-0 py-5 text-center">
            <div class="card-body">
                <i class="bi bi-file-earmark-person text-muted display-4 d-block mb-3"></i>
                <p class="text-muted fs-5 mb-0">Chưa có ứng viên nào nộp đơn cho vị trí này.</p>
                <a asp-page="/Dashboard/Index" class="btn btn-outline-primary mt-3">Quay lại Bảng điều khiển</a>
            </div>
        </div>
    }
    else
    {
        @foreach (var app in Model.Applications)
        {
            var candidate = app.Candidate;
            <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                <div class="card-header @(app.Status == ApplicationStatus.Accepted ? "bg-success text-white" : app.Status == ApplicationStatus.Rejected ? "bg-danger text-white" : "bg-dark text-white") py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-person-circle fs-4 me-2"></i>
                            <span class="fs-5 fw-bold">@candidate?.Name</span>
                        </div>
                        <div>
                            <span class="badge @(app.Status == ApplicationStatus.Accepted ? "bg-white text-success" : app.Status == ApplicationStatus.Rejected ? "bg-white text-danger" : "bg-warning text-dark") fs-6 px-3">
                                @(app.Status == ApplicationStatus.Accepted ? "Đã duyệt nhận" : app.Status == ApplicationStatus.Rejected ? "Đã từ chối" : "Chờ xử lý")
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <!-- Thông tin ứng viên -->
                        <div class="col-lg-4 border-end border-light-subtle mb-3 mb-lg-0">
                            <h5 class="border-bottom pb-2 fw-bold text-secondary"><i class="bi bi-card-list me-2"></i>Hồ sơ ứng viên</h5>
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-envelope text-primary me-2"></i><strong>Email:</strong> <a href="mailto:@candidate?.Email" class="text-decoration-none">@candidate?.Email</a></li>
                                <li class="mb-2"><i class="bi bi-telephone text-primary me-2"></i><strong>Điện thoại:</strong> @(candidate?.Phone ?? "Chưa cung cấp")</li>
                                <li class="mb-2"><i class="bi bi-briefcase text-primary me-2"></i><strong>Kinh nghiệm:</strong> @(candidate?.YearsOfExperience) năm</li>
                                <li class="mb-2"><i class="bi bi-cash text-primary me-2"></i><strong>Lương mong muốn:</strong> @(candidate?.ExpectedSalary.ToString("N0")) VNĐ</li>
                                <li class="mb-2"><i class="bi bi-geo-alt text-primary me-2"></i><strong>Nơi mong muốn:</strong> @(candidate?.PreferredLocation ?? "Bất kỳ")</li>
                                <li class="mb-2"><i class="bi bi-clock text-primary me-2"></i><strong>Ngày nộp:</strong> @app.AppliedAt.ToString("dd/MM/yyyy HH:mm")</li>
                            </ul>
                            @if (!string.IsNullOrEmpty(candidate?.Skills))
                            {
                                <div class="mt-3">
                                    <strong><i class="bi bi-tags text-primary me-1"></i> Kỹ năng:</strong>
                                    <div class="d-flex flex-wrap gap-1 mt-2">
                                        @foreach (var skill in candidate.GetSkillsList())
                                        {
                                            <span class="badge bg-light text-dark border">@skill</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="col-lg-8 ps-lg-4">
                            @if (!string.IsNullOrEmpty(app.CoverLetter) && app.CoverLetter.StartsWith("/uploads/"))
                            {
                                <h5 class="fw-bold text-secondary"><i class="bi bi-file-earmark-pdf-fill text-danger me-2"></i>File CV ứng viên</h5>
                                <div class="bg-light p-4 rounded mb-4 text-center border border-dashed border-2">
                                    <i class="bi bi-file-earmark-text-fill text-primary display-5 d-block mb-2 animate-bounce"></i>
                                    <p class="mb-3 text-dark fw-bold">Ứng viên đã tải lên file CV đính kèm.</p>
                                    <a href="@app.CoverLetter" target="_blank" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                                        <i class="bi bi-eye-fill me-1"></i> Xem trực tiếp & Tải CV
                                    </a>
                                </div>
                            }
                            else
                            {
                                <h5 class="fw-bold text-secondary"><i class="bi bi-chat-right-text me-2"></i>Thư giới thiệu</h5>
                                <div class="bg-light p-3 rounded mb-4" style="min-height: 80px; white-space: pre-wrap;">
                                    @(string.IsNullOrEmpty(app.CoverLetter) ? "Ứng viên không gửi thư giới thiệu." : app.CoverLetter)
                                </div>
                            }

                            @if (app.Status == ApplicationStatus.Pending)
                            {
                                <div class="card border-info bg-info bg-opacity-10">
                                    <div class="card-body">
                                        <h6 class="fw-bold text-info"><i class="bi bi-pencil-square me-2"></i>Xử lý đơn ứng tuyển</h6>
                                        <form method="post" class="mt-3">
                                            <input type="hidden" name="applicationId" value="@app.Id" />
                                            <input type="hidden" name="jobId" value="@Model.Job?.Id" />
                                            
                                            <div class="mb-3">
                                                <label class="form-label fw-bold">Ghi chú gửi ứng viên (nếu có):</label>
                                                <textarea class="form-control" name="notes" rows="2" placeholder="Ví dụ: Lịch phỏng vấn hoặc Lý do từ chối..."></textarea>
                                            </div>
                                            
                                            <div class="d-flex gap-2 justify-content-end">
                                                <button type="submit" asp-page-handler="Reject" class="btn btn-danger">
                                                    <i class="bi bi-x-circle me-1"></i> Từ chối
                                                </button>
                                                <button type="submit" asp-page-handler="Accept" class="btn btn-success">
                                                    <i class="bi bi-check-circle me-1"></i> Phê duyệt nhận
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="card border-secondary bg-light">
                                    <div class="card-body">
                                        <h6 class="fw-bold text-secondary"><i class="bi bi-info-circle me-2"></i>Thông tin phản hồi tuyển dụng</h6>
                                        <p class="mb-0 mt-2">
                                            <strong>Ghi chú phản hồi:</strong> 
                                            <span class="fst-italic text-muted">@(string.IsNullOrEmpty(app.EmployerNotes) ? "Không có ghi chú" : app.EmployerNotes)</span>
                                        </p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>
