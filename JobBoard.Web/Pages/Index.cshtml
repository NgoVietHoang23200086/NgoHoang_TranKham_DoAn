@page
@model JobBoard.Web.Pages.IndexModel
@{ ViewData["Title"] = "Trang chủ"; }

<section class="hero-section text-white text-center py-5" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);">
    <div class="container py-4">
        <h1 class="display-4 fw-bold mb-3">🔍 Tìm kiếm việc làm mơ ước</h1>
        <p class="lead mb-4">Kết nối ứng viên tài năng với nhà tuyển dụng hàng đầu Việt Nam</p>
        <form method="get" asp-page="/Jobs/Index" class="row g-3 justify-content-center">
            <div class="col-md-4">
                <input type="text" name="keyword" class="form-control form-control-lg" placeholder="Từ khóa (vd: C#, Java...)" />
            </div>
            <div class="col-md-3">
                <input type="text" name="location" class="form-control form-control-lg" placeholder="Địa điểm" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-lg w-100">🔍 Tìm kiếm</button>
            </div>
        </form>
    </div>
</section>

<section class="container py-5">
    <h2 class="text-center mb-4">💼 Việc làm mới nhất</h2>
    <div class="row g-4">
        @if (Model.LatestJobs != null)
        {
            @foreach (var job in Model.LatestJobs)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 job-card">
                        <div class="card-body">
                            <h5 class="card-title"><a asp-page="/Jobs/Details" asp-route-id="@job.Id" class="text-decoration-none">@job.Title</a></h5>
                            <p class="text-muted mb-1"><i class="bi bi-building"></i> @job.CompanyName</p>
                            <p class="mb-1"><i class="bi bi-geo-alt text-danger"></i> @job.Location</p>
                            <p class="mb-1"><i class="bi bi-cash text-success"></i> <strong>@job.Salary.ToString("N0") VNĐ</strong></p>
                            <p class="mb-2"><i class="bi bi-clock"></i> Hết hạn: @job.ExpiryDate.ToString("dd/MM/yyyy")</p>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var skill in job.RequiredSkills.Split(',', StringSplitOptions.TrimEntries).Take(3))
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary">@skill</span>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0">
                            <a asp-page="/Jobs/Details" asp-route-id="@job.Id" class="btn btn-outline-primary btn-sm w-100">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
    <div class="text-center mt-4">
        <a asp-page="/Jobs/Index" class="btn btn-primary btn-lg">Xem tất cả việc làm →</a>
    </div>
</section>

<section class="bg-light py-5">
    <div class="container">
        <h2 class="text-center mb-4">🎯 Tại sao chọn JobBoard VN?</h2>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="p-4"><i class="bi bi-shield-check display-4 text-primary"></i><h4 class="mt-3">Tin tuyển dụng chất lượng</h4><p class="text-muted">Tất cả tin đều được xác minh từ các công ty uy tín</p></div>
            </div>
            <div class="col-md-4">
                <div class="p-4"><i class="bi bi-robot display-4 text-success"></i><h4 class="mt-3">Gợi ý thông minh</h4><p class="text-muted">Thuật toán AI gợi ý việc làm phù hợp với kỹ năng</p></div>
            </div>
            <div class="col-md-4">
                <div class="p-4"><i class="bi bi-lightning-charge display-4 text-warning"></i><h4 class="mt-3">Ứng tuyển nhanh</h4><p class="text-muted">Chỉ một click để gửi đơn ứng tuyển</p></div>
            </div>
        </div>
    </div>
</section>
