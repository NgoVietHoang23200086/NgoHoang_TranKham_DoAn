@page
@using JobBoard.Domain.Enums
@model JobBoard.Web.Pages.Dashboard.IndexModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="container py-4">
    @if (Model.IsCandidate)
    {
        <h2 class="mb-4"><i class="bi bi-speedometer2"></i> Bảng điều khiển Ứng viên</h2>
        <div class="row g-4 mb-4">
            <div class="col-md-4"><div class="card bg-primary text-white shadow"><div class="card-body text-center"><h3>@Model.ApplicationCount</h3><p>Đơn đã ứng tuyển</p></div></div></div>
            <div class="col-md-4"><div class="card bg-success text-white shadow"><div class="card-body text-center"><h3>@Model.RecommendedCount</h3><p>Việc làm gợi ý</p></div></div></div>
            <div class="col-md-4"><div class="card bg-info text-white shadow"><div class="card-body text-center"><h3>@Model.CandidateProfile?.YearsOfExperience năm</h3><p>Kinh nghiệm</p></div></div></div>
        </div>

        @if (Model.DashboardText != null)
        {
            <div class="alert alert-info"><pre class="mb-0">@Model.DashboardText</pre></div>
        }

        <!-- Khu vực thông báo phản hồi mới cho Ứng viên -->
        @if (Model.RecentFeedbacks?.Any() == true)
        {
            <div class="alert alert-info border-info border-2 shadow-sm mb-4">
                <h5 class="alert-heading fw-bold text-info mb-3"><i class="bi bi-bell-fill me-2"></i>Thông báo phản hồi mới từ Nhà tuyển dụng!</h5>
                @foreach (var fb in Model.RecentFeedbacks)
                {
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge @(fb.Status == ApplicationStatus.Accepted ? "bg-success" : "bg-danger") me-2">
                            @(fb.Status == ApplicationStatus.Accepted ? "Đã duyệt nhận" : "Đã từ chối")
                        </span>
                        <span>
                            Công ty <strong>@fb.JobPost?.Employer?.CompanyName</strong> đã phản hồi đơn ứng tuyển của bạn cho vị trí <strong>@fb.JobPost?.Title</strong>. 
                            @if (!string.IsNullOrEmpty(fb.EmployerNotes))
                            {
                                <span>Phản hồi: <span class="fst-italic text-dark bg-white px-2 py-0.5 rounded border border-light-subtle">"@fb.EmployerNotes"</span></span>
                            }
                        </span>
                    </div>
                }
            </div>
        }

        <h4 class="mt-4">🎯 Việc làm gợi ý cho bạn (Dựa trên Thuật toán AI)</h4>
        @if (Model.RecommendedJobs?.Any() == true)
        {
            @foreach (var r in Model.RecommendedJobs)
            {
                <div class="card mb-3 shadow-sm border-start border-4 border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h5><a asp-page="/Jobs/Details" asp-route-id="@r.Job.Id" class="text-decoration-none">@r.Job.Title</a></h5>
                                <p class="text-muted mb-1"><i class="bi bi-building"></i> @r.Job.CompanyName | <i class="bi bi-geo-alt text-danger"></i> @r.Job.Location | <i class="bi bi-cash text-success"></i> @r.Job.Salary.ToString("N0") VNĐ</p>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-warning text-dark fs-6 mb-1">@r.MatchScore/100 điểm Match</span>
                                <br/><small class="text-muted">@r.MatchReason</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-light border">Chưa có việc làm gợi ý phù hợp. Hãy cập nhật kỹ năng của bạn.</div>
        }

        <h4 class="mt-4">📄 Đơn ứng tuyển của bạn</h4>
        @if (Model.Applications?.Any() == true)
        {
            <div class="table-responsive bg-white rounded shadow-sm">
                <table class="table table-hover mb-0">
                    <thead class="table-dark"><tr><th>Vị trí</th><th>Công ty</th><th>Ngày nộp</th><th>Trạng thái</th><th>Phản hồi tuyển dụng</th></tr></thead>
                    <tbody>
                        @foreach (var app in Model.Applications)
                        {
                            <tr>
                                <td><a asp-page="/Jobs/Details" asp-route-id="@app.JobPostId" class="text-decoration-none fw-bold">@app.JobPost?.Title</a></td>
                                <td>@app.JobPost?.Employer?.CompanyName</td>
                                <td>@app.AppliedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @(app.Status == ApplicationStatus.Accepted ? "bg-success" : app.Status == ApplicationStatus.Rejected ? "bg-danger" : "bg-warning text-dark")">
                                        @(app.Status == ApplicationStatus.Accepted ? "Đã nhận" : app.Status == ApplicationStatus.Rejected ? "Từ chối" : "Chờ xử lý")
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(app.EmployerNotes))
                                    {
                                        <div class="bg-light p-2 rounded border border-light-subtle small text-dark" style="max-width: 350px; white-space: pre-wrap;">
                                            <i class="bi bi-chat-quote-fill text-primary me-1"></i> @app.EmployerNotes
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><em>Chưa có phản hồi</em></span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else if (Model.IsEmployer)
    {
        <h2 class="mb-4"><i class="bi bi-speedometer2"></i> Bảng điều khiển Nhà tuyển dụng</h2>
        <div class="row g-4 mb-4">
            <div class="col-md-6"><div class="card bg-primary text-white shadow"><div class="card-body text-center"><h3>@Model.EmployerJobs?.Count()</h3><p>Tin tuyển dụng</p></div></div></div>
            <div class="col-md-6"><div class="card bg-success text-white shadow"><div class="card-body text-center"><h3>@Model.TotalApplicationsReceived</h3><p>Tổng đơn ứng tuyển nhận được</p></div></div></div>
        </div>

        @if (Model.DashboardText != null)
        {
            <div class="alert alert-info"><pre class="mb-0">@Model.DashboardText</pre></div>
        }

        <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
            <h4 class="mb-0">📝 Tin tuyển dụng của bạn</h4>
            <a asp-page="/Jobs/Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Đăng tin mới</a>
        </div>
        
        @if (Model.EmployerJobs?.Any() == true)
        {
            <div class="table-responsive bg-white rounded shadow-sm">
                <table class="table table-hover mb-0">
                    <thead class="table-dark"><tr><th>Tiêu đề</th><th>Lương</th><th>Ngày hết hạn</th><th>Trạng thái</th><th>Đơn ứng tuyển</th></tr></thead>
                    <tbody>
                        @foreach (var job in Model.EmployerJobs)
                        {
                            <tr>
                                <td><a asp-page="/Jobs/Details" asp-route-id="@job.Id" class="text-decoration-none fw-bold">@job.Title</a></td>
                                <td>@job.Salary.ToString("N0") VNĐ</td>
                                <td>@job.ExpiryDate.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-success">Active</span></td>
                                <td>
                                    @{
                                        int appCount = Model.JobApplicationCounts.ContainsKey(job.Id) ? Model.JobApplicationCounts[job.Id] : 0;
                                    }
                                    <a asp-page="/Jobs/Applications" asp-route-jobId="@job.Id" class="btn btn-sm @(appCount > 0 ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3">
                                        <i class="bi bi-file-earmark-person-fill me-1"></i> Xem (@appCount đơn)
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning">Vui lòng <a asp-page="/Account/Login">đăng nhập</a> để xem dashboard.</div>
    }
</div>
